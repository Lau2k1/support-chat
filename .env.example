# Example Environment Variables for support-chat Project

# Database configuration
database_host=YOUR_DATABASE_HOST
database_port=YOUR_DATABASE_PORT
database_user=YOUR_DATABASE_USER
database_password=YOUR_DATABASE_PASSWORD

database_name=YOUR_DATABASE_NAME

# JWT settings
jwt_secret=YOUR_JWT_SECRET
token_expiration=YOUR_TOKEN_EXPIRATION_TIME

# API Keys
api_key_service_1=YOUR_API_KEY_1
api_key_service_2=YOUR_API_KEY_2

# Logging Configuration
logging_level=YOUR_LOGGING_LEVEL
logging_file_path=YOUR_LOGGING_FILE_PATH